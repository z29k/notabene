{
  "name": "@z29k/notabene",
  "version": "0.8.1",
  "description": "Navigable docs renderer + human↔agent review loop. Leave review comments right on your rendered docs; an agent reads .notabene/, applies the feedback, and journals it.",
  "type": "module",
  "license": "MIT",
  "author": "z29k",
  "homepage": "https://github.com/z29k/notabene#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z29k/notabene.git",
    "directory": "packages/renderer"
  },
  "bugs": {
    "url": "https://github.com/z29k/notabene/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "notabene": "bin/notabene.mjs"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "astro.config.mjs",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "node bin/notabene.mjs dev",
    "build": "node bin/notabene.mjs build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "astro check",
    "lint": "biome check bin src test",
    "format": "biome format --write bin src test"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.6",
    "@astrojs/node": "10.0.6",
    "astro": "^6.0.0",
    "mermaid": "^11.16.0"
  },
  "peerDependencies": {
    "puppeteer": ">=23"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "docs",
    "documentation",
    "review",
    "comments",
    "mdx",
    "markdown",
    "astro",
    "ai",
    "agent"
  ],
  "engines": {
    "node": ">=22.12.0"
  }
}
