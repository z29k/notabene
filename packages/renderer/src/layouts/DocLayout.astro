---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import Comments from "../components/Comments.astro";
import type { Space } from "../lib/nav";
import { author, clientRoots, locale, reviewMode, siteName, tagline } from "../config.mjs";
import { t } from "../i18n.mjs";

const m = t(locale);

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  current?: string;
  space?: Space;
  /** Chemin logique repo-relatif (sans extension) — support Phase 2 commentaires. */
  page?: string;
  headings?: Heading[];
  breadcrumb?: Crumb[];
}

const { title, current = "", space, page, headings = [], breadcrumb = [] } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} · {siteName}</title>
    <script type="application/json" id="notabene-roots" is:inline set:html={JSON.stringify(clientRoots)} />
    <script type="application/json" id="notabene-i18n" is:inline set:html={JSON.stringify(m)} />
    <script type="application/json" id="notabene-review" is:inline set:html={JSON.stringify({ mode: reviewMode })} />
    <script type="application/json" id="notabene-me" is:inline set:html={JSON.stringify({ author })} />
  </head>
  <body>
    <header class="topbar">
      <button
        id="nb-nav-toggle"
        class="nb-nav-toggle"
        type="button"
        aria-label={m.menu}
        aria-controls="nb-sidebar"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <a href="/" class="brand">{siteName} <span>· {tagline}</span></a>
      <div class="search">
        <input id="search-input" type="search" placeholder={m.searchPlaceholder} autocomplete="off" />
        <div id="search-results" class="search-results" hidden></div>
      </div>
      <a href="/comments" class="topbar-link topbar-util">{m.navComments}</a>
      <a href="/review" id="nav-review" class="topbar-link topbar-util js-review-link" hidden>
        {m.navReview} <span id="nav-review-badge" class="review-badge js-review-badge"></span>
      </a>
      <a href="/journal" class="topbar-link topbar-util">{m.navJournal}</a>
      <label class="topbar-me topbar-util" title={m.yourNameHint}>
        <span aria-hidden="true">👤</span>
        <input id="me-input" type="text" placeholder={m.yourName} autocomplete="off" aria-label={m.yourName} />
      </label>
      <button id="nb-cmt-sheet-btn" class="nb-cmt-sheet-btn" type="button" hidden aria-label={m.annotations}>
        <span aria-hidden="true">💬</span> <span id="nb-cmt-sheet-count" class="nb-cmt-sheet-count"></span>
      </button>
    </header>

    <div class="shell">
      <aside class="sidebar" id="nb-sidebar" tabindex="-1">
        <Sidebar current={current} activeSpace={space} />
        <nav class="drawer-util" aria-label={m.menu}>
          <a href="/comments" class="drawer-link">{m.navComments}</a>
          <a href="/review" class="drawer-link js-review-link" hidden>
            {m.navReview} <span class="review-badge js-review-badge"></span>
          </a>
          <a href="/journal" class="drawer-link">{m.navJournal}</a>
          <label class="drawer-me" title={m.yourNameHint}>
            <span aria-hidden="true">👤</span>
            <input
              id="me-input-drawer"
              type="text"
              placeholder={m.yourName}
              autocomplete="off"
              aria-label={m.yourName}
            />
          </label>
        </nav>
      </aside>

      <main class="content">
        {
          breadcrumb.length > 0 && (
            <nav class="breadcrumb" aria-label="Breadcrumb">
              {breadcrumb.map((b, i) => (
                <>
                  {i > 0 && <span class="sep">/</span>}
                  {b.href ? <a href={b.href}>{b.label}</a> : <span>{b.label}</span>}
                </>
              ))}
            </nav>
          )
        }
        {
          headings.length > 0 && (
            <details class="toc-inline">
              <summary>{m.tocTitle}</summary>
              <Toc headings={headings} />
            </details>
          )
        }
        <article id="doc-content" class="prose" data-space={space} data-page={page}>
          <slot />
        </article>
        <Comments page={page} space={space} />
      </main>

      <aside class="rail">
        <Toc headings={headings} />
        <div id="cmt-rail" class="cmt-rail" role="region" aria-label={m.annotations}></div>
      </aside>
    </div>

    <div id="nb-scrim" class="nb-scrim" hidden></div>

    <script>
      import { getAuthor, setAuthor } from "../lib/client/comments-client";
      import { closeOverlay, currentOverlay, initShell, openOverlay } from "../lib/client/shell";

      // Wire the shared scrim / Escape / resize-to-desktop overlay closers once.
      initShell();

      // Identity: the top-bar AND drawer name inputs are the per-device comment author
      // (localStorage), pre-filled with the server default (config author / git user.name /
      // "you") and kept in sync with each other.
      const meCfg = JSON.parse(document.getElementById("notabene-me")?.textContent || "{}");
      const meInputs = Array.from(
        document.querySelectorAll<HTMLInputElement>("#me-input, #me-input-drawer"),
      );
      for (const el of meInputs) {
        el.value = getAuthor(meCfg.author || "you");
        el.addEventListener("change", () => {
          setAuthor(el.value);
          for (const other of meInputs) if (other !== el) other.value = el.value;
        });
      }

      // Hamburger → off-canvas nav drawer (compact only; the button is CSS-hidden on
      // desktop). Uses the shared overlay machinery (scrim, inert, scroll-lock, Escape).
      const navToggle = document.getElementById("nb-nav-toggle");
      const sidebar = document.getElementById("nb-sidebar");
      if (navToggle && sidebar) {
        const closeDrawer = () => {
          sidebar.classList.remove("nb-open");
          navToggle.setAttribute("aria-expanded", "false");
        };
        navToggle.addEventListener("click", () => {
          if (currentOverlay() === "drawer") {
            closeOverlay();
            return;
          }
          sidebar.classList.add("nb-open");
          navToggle.setAttribute("aria-expanded", "true");
          openOverlay("drawer", sidebar, closeDrawer, sidebar);
        });
        // Following a link inside the drawer navigates away → close it first.
        sidebar.addEventListener("click", (e) => {
          if ((e.target as HTMLElement).closest("a") && currentOverlay() === "drawer") closeOverlay();
        });
      }

      // Review badge: reveal every "Review" link (topbar + drawer) + a count of
      // `addressed` comments when in approve mode, OR whenever any addressed comment
      // exists (so none get stuck if the mode is flipped back to auto). One tiny fetch.
      const reviewCfg = JSON.parse(document.getElementById("notabene-review")?.textContent || "{}");
      const reviewLinks = Array.from(document.querySelectorAll<HTMLElement>(".js-review-link"));
      const reviewBadges = Array.from(document.querySelectorAll<HTMLElement>(".js-review-badge"));
      if (reviewLinks.length) {
        fetch("/api/comments?all=1")
          .then((r) => r.json())
          .then((all: { status: string }[]) => {
            const n = Array.isArray(all) ? all.filter((c) => c.status === "addressed").length : 0;
            if (reviewCfg.mode === "approve" || n > 0) {
              for (const l of reviewLinks) l.hidden = false;
              for (const b of reviewBadges) {
                b.textContent = n ? String(n) : "";
                b.hidden = !n;
              }
            }
          })
          .catch(() => {});
      }
    </script>

    <script>
      import { renderMermaid } from "../lib/client/mermaid";

      // Render any ```mermaid diagrams on the page (lazy-loads mermaid only if present).
      // No ClientRouter here, so a direct call covers every full page load; the listener
      // is a harmless no-op unless view transitions are added later.
      renderMermaid();
      document.addEventListener("astro:page-load", () => renderMermaid());
    </script>

    <script>
      import { esc } from "../lib/client/comments-client";

      // Client-side search: JSON index (title + headings + excerpt), scored.
      const input = document.getElementById("search-input") as HTMLInputElement | null;
      const box = document.getElementById("search-results");

      interface Doc {
        space: string;
        href: string;
        title: string;
        headings: string[];
        text: string;
      }

      const ROOTS: { key: string; label: string; path: string }[] = JSON.parse(
        document.getElementById("notabene-roots")?.textContent || "[]",
      );
      const M: Record<string, string> = JSON.parse(
        document.getElementById("notabene-i18n")?.textContent || "{}",
      );
      const spaceLabel = (key: string): string =>
        ROOTS.find((r) => r.key === key)?.label ?? key;

      let index: Doc[] | null = null;
      async function ensureIndex(): Promise<Doc[]> {
        if (!index) index = await fetch("/search-index.json").then((r) => r.json());
        return index ?? [];
      }

      function score(doc: Doc, q: string): number {
        const t = doc.title.toLowerCase();
        if (t === q) return 100;
        if (t.startsWith(q)) return 80;
        if (t.includes(q)) return 60;
        if (doc.headings.some((h) => h.toLowerCase().includes(q))) return 30;
        if (doc.text.toLowerCase().includes(q)) return 10;
        return 0;
      }

      if (input && box) {
        input.addEventListener("input", async () => {
          const q = input.value.trim().toLowerCase();
          if (!q) {
            box.hidden = true;
            box.innerHTML = "";
            return;
          }
          const data = await ensureIndex();
          const hits = data
            .map((doc) => ({ doc, s: score(doc, q) }))
            .filter((x) => x.s > 0)
            .sort((a, b) => b.s - a.s)
            .slice(0, 12);
          box.innerHTML = hits.length
            ? hits
                .map(
                  ({ doc }) =>
                    `<a href="${doc.href}"><span class="r-space ${doc.space}">${esc(spaceLabel(doc.space))}</span><span class="r-title">${esc(doc.title)}</span></a>`,
                )
                .join("")
            : `<div class="r-empty">${M.searchNoResults}</div>`;
          box.hidden = false;
        });

        document.addEventListener("click", (e) => {
          const target = e.target as Node;
          if (!box.contains(target) && target !== input) box.hidden = true;
        });
      }
    </script>
  </body>
</html>
