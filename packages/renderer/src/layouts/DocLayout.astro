---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import Comments from "../components/Comments.astro";
import type { Space } from "../lib/nav";
import { author, authorEmail, clientI18n, clientRoots, pdf, reviewMode, siteName, tagline } from "../config.mjs";
import { t } from "../i18n.mjs";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Crumb {
  label: string;
  href?: string;
}

/** Contextual PDF export targets for the current page (built by the page route from
 *  its space + entry id). The whole-doc target (/print) is always offered. */
interface ExportScopes {
  space?: { href: string; label: string };
  folder?: { href: string; label: string };
  page?: { href: string; label: string };
}

interface Alt {
  locale: string;
  href: string;
  /** True when this is a REAL translation of the page (vs. a home fallback) — hreflang only. */
  translated?: boolean;
}

interface Props {
  title: string;
  current?: string;
  space?: Space;
  /** Chemin logique repo-relatif (sans extension) — support Phase 2 commentaires. */
  page?: string;
  /** Content locale of THIS page (per-page chrome). Aggregate pages omit it → default. */
  locale?: string;
  headings?: Heading[];
  breadcrumb?: Crumb[];
  exportScopes?: ExportScopes;
  /** Equivalent pages in other locales — drives the language switcher + hreflang. */
  alternates?: Alt[];
  /** Aggregate pages (comments/journal/review/…): no per-page locale, so localize the chrome
   *  CLIENT-SIDE to the visitor's current language (localStorage) + show a client switcher. */
  i18nClientChrome?: boolean;
}

const {
  title,
  current = "",
  space,
  page,
  locale = clientI18n.defaultLocale,
  headings = [],
  breadcrumb = [],
  exportScopes,
  alternates = [],
  i18nClientChrome = false,
} = Astro.props;
// UI chrome follows THIS page's locale (t() falls back to English per key).
const m = t(locale);
const showLang = clientI18n.enabled && alternates.length > 1;
// Aggregate pages: ship EVERY locale's catalog so the client can re-localize the chrome to
// the visitor's current language (no per-page locale to key off server-side).
const clientChrome = i18nClientChrome && clientI18n.enabled;
const i18nAll = clientChrome ? Object.fromEntries(clientI18n.locales.map((l: string) => [l, t(l)])) : null;
// Runs in <head> BEFORE any list script: pick the visitor's current language (localStorage)
// → set <html lang> + swap the page-locale catalog so everything downstream (fetched lists,
// dates) uses it. Injected via set:html (an is:inline body is raw text, not interpolated).
const earlyLocaleScript =
  "(function(){try{var all=JSON.parse(document.getElementById('notabene-i18n-all').textContent);" +
  "var cfg=JSON.parse(document.getElementById('notabene-i18n-config').textContent);" +
  "var loc=localStorage.getItem('nb-locale');if(!loc||!all[loc])loc=cfg.defaultLocale;" +
  "document.documentElement.lang=loc;var one=document.getElementById('notabene-i18n');" +
  "if(one)one.textContent=JSON.stringify(all[loc]);}catch(e){}})();";
// Endonym for a locale (e.g. "Français"), shown in the language dropdown — via Intl so it's
// not a hardcoded UI string; falls back to the uppercased code.
const langName = (loc: string) => {
  try {
    const n = new Intl.DisplayNames([loc], { type: "language" }).of(loc);
    return n ? n.charAt(0).toUpperCase() + n.slice(1) : loc.toUpperCase();
  } catch {
    return loc.toUpperCase();
  }
};
// hreflang lists only REAL translations (+ x-default = the default locale's page).
const hreflangs = alternates.filter((a) => a.translated);
const xDefault = hreflangs.find((a) => a.locale === clientI18n.defaultLocale)?.href ?? hreflangs[0]?.href;
// Language-preference redirect (doc pages): the visitor's chosen language (localStorage,
// set by the switcher) wins. Landing on a page in another language that HAS an equivalent →
// redirect to it. `altMap` = { locale: href } of the real translations of THIS page.
const altMap =
  clientI18n.enabled && !i18nClientChrome && hreflangs.length > 1
    ? Object.fromEntries(hreflangs.map((a) => [a.locale, a.href]))
    : null;
const redirectScript =
  "(function(){try{var alts=JSON.parse(document.getElementById('notabene-i18n-alts').textContent);" +
  "var pref=localStorage.getItem('nb-locale');var cur=document.documentElement.lang;" +
  "if(pref&&pref!==cur&&alts[pref])location.replace(alts[pref]);}catch(e){}})();";
// Doc page MISSING at least one locale → ship the locales it DOES have + the (per-locale)
// "not translated" notice, so the client can show a discreet banner when the visitor's
// preferred language isn't among them (no redirect fired, they're reading the fallback).
const docLangs = clientI18n.enabled && !i18nClientChrome ? hreflangs.map((a) => a.locale) : null;
const showBanner = !!docLangs && docLangs.length < clientI18n.locales.length;
const bannerTpl = showBanner ? Object.fromEntries(clientI18n.locales.map((l: string) => [l, t(l).pageNotTranslated])) : null;
const showExport = pdf.enabled;
// Export links open the print view in a NEW TAB and auto-open the browser's print
// dialog (?autoprint=1, handled by lib/client/print.ts) — as close to "save straight to
// PDF" as a browser allows. The silent file-export path is the `notabene pdf` CLI.
const printHref = (href: string) => `${href}?autoprint=1`;
// Whole-doc PDF is per-locale (default unprefixed): /print or /print/<locale>.
const wholeDocHref = locale === clientI18n.defaultLocale ? "/print" : `/print/${locale}`;
// Doc pages (page set) carry the TOC + anchored-comment rail. App pages (review / comments /
// journal) pass no page → no rail; drop the empty third column so they use the full width.
const hasRail = page != null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} · {siteName}</title>
    <script type="application/json" id="notabene-roots" is:inline set:html={JSON.stringify(clientRoots)} />
    <script type="application/json" id="notabene-i18n" is:inline set:html={JSON.stringify(m)} />
    <script type="application/json" id="notabene-review" is:inline set:html={JSON.stringify({ mode: reviewMode })} />
    <script type="application/json" id="notabene-me" is:inline set:html={JSON.stringify({ author, email: authorEmail })} />
    <script type="application/json" id="notabene-i18n-config" is:inline set:html={JSON.stringify(clientI18n)} />
    {i18nAll && <script type="application/json" id="notabene-i18n-all" is:inline set:html={JSON.stringify(i18nAll)} />}
    {i18nAll && <script is:inline set:html={earlyLocaleScript} />}
    {altMap && <script type="application/json" id="notabene-i18n-alts" is:inline set:html={JSON.stringify(altMap)} />}
    {altMap && <script is:inline set:html={redirectScript} />}
    {showBanner && <script type="application/json" id="notabene-i18n-langs" is:inline set:html={JSON.stringify(docLangs)} />}
    {bannerTpl && <script type="application/json" id="notabene-i18n-banner" is:inline set:html={JSON.stringify(bannerTpl)} />}
    {showLang && hreflangs.map((a) => <link rel="alternate" hreflang={a.locale} href={a.href} />)}
    {showLang && xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}
  </head>
  <body>
    <header class="topbar">
      <button
        id="nb-nav-toggle"
        class="nb-nav-toggle"
        type="button"
        aria-label={m.menu}
        aria-controls="nb-sidebar"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <a href="/" class="brand">{siteName} <span>· {tagline}</span></a>
      <div class="search">
        <input id="search-input" type="search" placeholder={m.searchPlaceholder} data-i18n-ph="searchPlaceholder" autocomplete="off" />
        <div id="search-results" class="search-results" hidden></div>
      </div>
      <a href="/comments" class="topbar-link topbar-util" data-i18n="navComments">{m.navComments}</a>
      <a href="/review" id="nav-review" class="topbar-link topbar-util js-review-link" hidden>
        <span data-i18n="navReview">{m.navReview}</span> <span id="nav-review-badge" class="review-badge js-review-badge"></span>
      </a>
      <a href="/journal" class="topbar-link topbar-util" data-i18n="navJournal">{m.navJournal}</a>
      {/* Flexible gap: keeps Comments/Journal on the left, pushes the ancillary
          language + Export + name group to the far right (desktop only — utils collapse
          into the drawer on compact). */}
      <div class="topbar-spacer topbar-util" aria-hidden="true"></div>
      {
        showLang && (
          <details class="lang-menu topbar-util">
            <summary class="topbar-link lang-summary" aria-label={m.language} title={m.language}>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              <span class="lang-current">{locale.toUpperCase()}</span>
            </summary>
            <div class="lang-menu-pop">
              {alternates.map((a) => (
                <a
                  href={a.href}
                  hreflang={a.locale}
                  lang={a.locale}
                  class:list={["lang-opt-row", { active: a.locale === locale }]}
                  aria-current={a.locale === locale ? "true" : undefined}
                >
                  <span class="lang-code">{a.locale.toUpperCase()}</span>
                  <span class="lang-name">{langName(a.locale)}</span>
                </a>
              ))}
            </div>
          </details>
        )
      }
      {
        /* Aggregate pages: a client-side switcher — picks the chrome language in place (no
           URL change), persists it, reloads so the lists re-render in that language. */
        clientChrome && (
          <details class="lang-menu topbar-util" id="nb-lang-client">
            <summary class="topbar-link lang-summary" aria-label={m.language} title={m.language}>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              <span class="lang-current" id="nb-lang-current">{clientI18n.defaultLocale.toUpperCase()}</span>
            </summary>
            <div class="lang-menu-pop">
              {clientI18n.locales.map((loc: string) => (
                <button type="button" class="lang-opt-row" data-locale={loc} lang={loc}>
                  <span class="lang-code">{loc.toUpperCase()}</span>
                  <span class="lang-name">{langName(loc)}</span>
                </button>
              ))}
            </div>
          </details>
        )
      }
      {
        showExport && (
          <details class="export-menu topbar-util">
            <summary class="topbar-link export-summary" aria-label={m.exportPdf} title={m.exportPdf} data-i18n-aria="exportPdf">
              <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 6 2 18 2 18 9" />
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                <rect x="6" y="14" width="12" height="8" />
              </svg>
            </summary>
            <div class="export-menu-pop">
              {exportScopes?.page && (
                <a href={printHref(exportScopes.page.href)} target="_blank" rel="noopener" data-i18n="exportThisPage">
                  {m.exportThisPage}
                </a>
              )}
              {exportScopes?.folder && (
                <a href={printHref(exportScopes.folder.href)} target="_blank" rel="noopener" data-i18n="exportThisFolder">
                  {m.exportThisFolder}
                </a>
              )}
              {exportScopes?.space && (
                <a href={printHref(exportScopes.space.href)} target="_blank" rel="noopener" data-i18n="exportThisSpace">
                  {m.exportThisSpace}
                </a>
              )}
              <a href={printHref(wholeDocHref)} target="_blank" rel="noopener" data-i18n="exportWholeDoc">
                {m.exportWholeDoc}
              </a>
            </div>
          </details>
        )
      }
      <button id="nb-identity-chip" class="topbar-me topbar-util" type="button" title={m.identityHint} aria-label={m.identityHint} data-i18n-aria="identityHint">
        <span aria-hidden="true">👤</span>
        <span class="nb-identity-name"></span>
      </button>
      <button id="nb-cmt-sheet-btn" class="nb-cmt-sheet-btn" type="button" hidden aria-label={m.annotations}>
        <span aria-hidden="true">💬</span> <span id="nb-cmt-sheet-count" class="nb-cmt-sheet-count"></span>
      </button>
    </header>

    <div class:list={["shell", { "shell--full": !hasRail }]}>
      <aside class="sidebar" id="nb-sidebar" tabindex="-1">
        <Sidebar current={current} activeSpace={space} locale={locale} />
        <nav class="drawer-util" aria-label={m.menu}>
          <a href="/comments" class="drawer-link" data-i18n="navComments">{m.navComments}</a>
          <a href="/review" class="drawer-link js-review-link" hidden>
            <span data-i18n="navReview">{m.navReview}</span> <span class="review-badge js-review-badge"></span>
          </a>
          <a href="/journal" class="drawer-link" data-i18n="navJournal">{m.navJournal}</a>
          {
            showLang && (
              <nav class="lang-switch-drawer" aria-label={m.language}>
                {alternates.map((a) => (
                  <a
                    href={a.href}
                    hreflang={a.locale}
                    lang={a.locale}
                    class:list={["drawer-link lang-opt", { active: a.locale === locale }]}
                    aria-current={a.locale === locale ? "true" : undefined}
                  >
                    🌐 {a.locale.toUpperCase()}
                  </a>
                ))}
              </nav>
            )
          }
          {
            showExport && (
              <>
                {exportScopes?.page && (
                  <a href={printHref(exportScopes.page.href)} target="_blank" rel="noopener" class="drawer-link">
                    🖨 {m.exportThisPage}
                  </a>
                )}
                {exportScopes?.folder && (
                  <a href={printHref(exportScopes.folder.href)} target="_blank" rel="noopener" class="drawer-link">
                    🖨 {m.exportThisFolder}
                  </a>
                )}
                {exportScopes?.space && (
                  <a href={printHref(exportScopes.space.href)} target="_blank" rel="noopener" class="drawer-link">
                    🖨 {m.exportThisSpace}
                  </a>
                )}
                <a href={printHref(wholeDocHref)} target="_blank" rel="noopener" class="drawer-link">
                  🖨 {m.exportWholeDoc}
                </a>
              </>
            )
          }
          <button id="nb-identity-chip-drawer" class="drawer-me" type="button" aria-label={m.identityHint}>
            <span aria-hidden="true">👤</span>
            <span class="nb-identity-name"></span>
          </button>
        </nav>
      </aside>

      <main class="content">
        {showBanner && <div id="nb-i18n-banner" class="i18n-banner" role="status" hidden />}
        {
          breadcrumb.length > 0 && (
            <nav class="breadcrumb" aria-label="Breadcrumb">
              {breadcrumb.map((b, i) => (
                <>
                  {i > 0 && <span class="sep">/</span>}
                  {b.href ? <a href={b.href}>{b.label}</a> : <span>{b.label}</span>}
                </>
              ))}
            </nav>
          )
        }
        {
          headings.length > 0 && (
            <details class="toc-inline">
              <summary>{m.tocTitle}</summary>
              <Toc headings={headings} locale={locale} />
            </details>
          )
        }
        <article id="doc-content" class="prose" data-space={space} data-page={page}>
          <slot />
        </article>
        <Comments page={page} space={space} locale={locale} />
      </main>

      {
        hasRail && (
          <aside class="rail">
            <Toc headings={headings} locale={locale} />
            <div id="cmt-rail" class="cmt-rail" role="region" aria-label={m.annotations} />
          </aside>
        )
      }
    </div>

    <div id="nb-scrim" class="nb-scrim" hidden></div>

    <dialog id="nb-identity-dialog" class="nb-dialog">
      <form id="nb-identity-form" class="nb-identity-form" method="dialog" novalidate>
        <h2>{m.identityTitle}</h2>
        <p id="nb-identity-lede" class="nb-identity-lede">{m.identityLede}</p>
        <label class="nb-field">
          <span class="nb-field-label">{m.identityName}</span>
          <input id="nb-identity-name" type="text" required autocomplete="name" placeholder={m.yourName} />
        </label>
        <label class="nb-field">
          <span class="nb-field-label">{m.identityEmail} <em>{m.identityEmailOptional}</em></span>
          <input id="nb-identity-email" type="email" autocomplete="email" placeholder="you@example.com" />
          <small class="nb-hint">{m.identityEmailHint}</small>
        </label>
        <div class="nb-identity-actions">
          <button type="button" id="nb-identity-cancel" class="nb-btn-ghost">{m.cancel}</button>
          <button type="submit" id="nb-identity-save" class="nb-btn">{m.save}</button>
        </div>
      </form>
    </dialog>

    <script>
      import { getIdentity, hasIdentity, isLoopbackHost, setIdentity } from "../lib/client/comments-client";
      import { closeOverlay, currentOverlay, initShell, openOverlay } from "../lib/client/shell";
      import { localizeField } from "../lib/i18n-content.mjs";

      // Wire the shared scrim / Escape / resize-to-desktop overlay closers once.
      initShell();

      // i18n chrome. Doc pages carry their locale in <html lang> → remember it as the
      // visitor's CURRENT language. Aggregate pages ship every catalog (#notabene-i18n-all)
      // and have no per-page locale: the head script already picked the current language
      // into <html lang> + swapped the client catalog; here we re-localize the static chrome
      // and wire the in-place switcher (persist + reload → the fetched lists re-render).
      {
        const i18nAllEl = document.getElementById("notabene-i18n-all");
        const i18nCfg = JSON.parse(document.getElementById("notabene-i18n-config")?.textContent || "null");
        if (i18nCfg?.enabled && !i18nAllEl) {
          // Doc page: the switcher records the visitor's EXPLICIT language preference (the
          // head redirect then enforces it on every page). Set it before navigating so the
          // target page — already in that language — isn't bounced back.
          for (const a of document.querySelectorAll<HTMLAnchorElement>(".lang-menu a[hreflang], .lang-switch-drawer a[hreflang]")) {
            a.addEventListener("click", () => localStorage.setItem("nb-locale", a.getAttribute("hreflang") || ""));
          }
          // Banner: a preferred language is set but this page has no version in it (so no
          // redirect fired) → tell the visitor, in their language, they're reading a fallback.
          const bannerEl = document.getElementById("nb-i18n-banner");
          const langsEl = document.getElementById("notabene-i18n-langs");
          const pref = localStorage.getItem("nb-locale");
          if (bannerEl && langsEl && pref && !JSON.parse(langsEl.textContent || "[]").includes(pref)) {
            const tpl = JSON.parse(document.getElementById("notabene-i18n-banner")?.textContent || "{}");
            const cur = document.documentElement.lang;
            let name = cur;
            try {
              name = new Intl.DisplayNames([pref], { type: "language" }).of(cur) || cur;
            } catch {}
            bannerEl.textContent = (tpl[pref] || tpl[cur] || "").replace("{lang}", name);
            bannerEl.hidden = false;
          }
        } else if (i18nAllEl) {
          const all = JSON.parse(i18nAllEl.textContent || "{}");
          const loc = document.documentElement.lang;
          const cat = all[loc] || {};
          const set = (sel: string, fn: (el: HTMLElement, v: string) => void) => {
            for (const el of document.querySelectorAll<HTMLElement>(sel)) {
              const k = el.getAttribute(sel.slice(1, -1));
              if (k && cat[k] != null) fn(el, cat[k]);
            }
          };
          set("[data-i18n]", (el, v) => {
            el.textContent = v;
          });
          set("[data-i18n-ph]", (el, v) => el.setAttribute("placeholder", v));
          set("[data-i18n-aria]", (el, v) => {
            el.setAttribute("aria-label", v);
            el.setAttribute("title", v);
          });
          for (const el of document.querySelectorAll<HTMLElement>("[data-i18n-date]")) {
            const iso = el.getAttribute("data-i18n-date");
            if (iso)
              try {
                el.textContent = new Date(`${iso}T00:00:00Z`).toLocaleDateString(loc, { dateStyle: "medium", timeZone: "UTC" });
              } catch {}
          }
          // Per-locale roots[].label / .description: cards (home / 404) and the comments space
          // filter render the default-locale string server-side; re-localize to `loc` here.
          const rootsEl = document.getElementById("notabene-roots");
          if (rootsEl) {
            const rootsData = JSON.parse(rootsEl.textContent || "[]");
            const def = i18nCfg?.defaultLocale || loc;
            const byKey: Record<string, (typeof rootsData)[number]> = {};
            for (const r of rootsData) byKey[r.key] = r;
            const relabel = (attr: string, field: "labelI18n" | "descriptionI18n") => {
              for (const el of document.querySelectorAll<HTMLElement>(`[${attr}]`)) {
                const r = byKey[el.getAttribute(attr) || ""];
                const v = r && localizeField(r[field], loc, def);
                if (v != null) el.textContent = v;
              }
            };
            relabel("data-nb-root-label", "labelI18n");
            relabel("data-nb-root-desc", "descriptionI18n");
          }
          const cur = document.getElementById("nb-lang-current");
          if (cur) cur.textContent = loc.toUpperCase();
          for (const btn of document.querySelectorAll<HTMLElement>("#nb-lang-client [data-locale]")) {
            const l = btn.getAttribute("data-locale");
            btn.classList.toggle("active", l === loc);
            btn.addEventListener("click", () => {
              if (l) {
                localStorage.setItem("nb-locale", l);
                location.reload();
              }
            });
          }
        }
      }

      // Identity (name + optional email) — per-device, edited via a modal. The chips in
      // the topbar + drawer open it; on a non-loopback (LAN/`--host`/deployed) host with no
      // identity set yet, it's forced open before the visitor can interact, so comments are
      // attributed to a real person rather than the repo owner's git default.
      const meCfg = JSON.parse(document.getElementById("notabene-me")?.textContent || "{}");
      const M = JSON.parse(document.getElementById("notabene-i18n")?.textContent || "{}");
      const defName = meCfg.author || "you";
      const defEmail = meCfg.email || "";

      const dialog = document.getElementById("nb-identity-dialog") as HTMLDialogElement | null;
      const form = document.getElementById("nb-identity-form") as HTMLFormElement | null;
      const nameInput = document.getElementById("nb-identity-name") as HTMLInputElement | null;
      const emailInput = document.getElementById("nb-identity-email") as HTMLInputElement | null;
      const cancelBtn = document.getElementById("nb-identity-cancel") as HTMLButtonElement | null;
      const lede = document.getElementById("nb-identity-lede");
      const chips = Array.from(document.querySelectorAll("#nb-identity-chip, #nb-identity-chip-drawer"));
      const nameLabels = Array.from(document.querySelectorAll<HTMLElement>(".nb-identity-name"));

      let forced = false;

      const refreshChips = () => {
        const { name } = getIdentity(defName, defEmail);
        for (const el of nameLabels) el.textContent = name;
      };
      refreshChips();

      const openIdentity = (force = false) => {
        if (!dialog) return;
        forced = force;
        const known = hasIdentity();
        const cur = getIdentity(defName, defEmail);
        // On a forced remote prompt with nothing stored, start blank so the visitor
        // enters THEIR identity rather than accepting the repo owner's git default.
        if (nameInput) nameInput.value = force && !known ? "" : cur.name;
        if (emailInput) emailInput.value = force && !known ? "" : cur.email;
        if (lede) lede.textContent = force ? M.identityNudge : M.identityLede;
        if (cancelBtn) cancelBtn.hidden = force;
        if (!dialog.open) dialog.showModal();
        nameInput?.focus();
      };

      form?.addEventListener("submit", (e) => {
        e.preventDefault();
        const name = nameInput?.value.trim() || "";
        const email = emailInput?.value.trim() || "";
        if (!name) {
          nameInput?.setCustomValidity(M.identityNameRequired || "Required");
          nameInput?.reportValidity();
          return;
        }
        if (email && emailInput && !emailInput.checkValidity()) {
          emailInput.reportValidity();
          return;
        }
        setIdentity({ name, email });
        refreshChips();
        forced = false;
        dialog?.close();
      });

      nameInput?.addEventListener("input", () => nameInput.setCustomValidity(""));
      cancelBtn?.addEventListener("click", () => {
        if (!forced) dialog?.close();
      });
      // Block Escape / backdrop dismissal while the identity is being forced.
      dialog?.addEventListener("cancel", (e) => {
        if (forced) e.preventDefault();
      });
      for (const chip of chips) chip.addEventListener("click", () => openIdentity(false));

      // Gate: remote host + no identity yet → force the dialog before browsing.
      if (!isLoopbackHost(location.hostname) && !hasIdentity()) openIdentity(true);

      // Hamburger → off-canvas nav drawer (compact only; the button is CSS-hidden on
      // desktop). Uses the shared overlay machinery (scrim, inert, scroll-lock, Escape).
      const navToggle = document.getElementById("nb-nav-toggle");
      const sidebar = document.getElementById("nb-sidebar");
      if (navToggle && sidebar) {
        const closeDrawer = () => {
          sidebar.classList.remove("nb-open");
          navToggle.setAttribute("aria-expanded", "false");
        };
        navToggle.addEventListener("click", () => {
          if (currentOverlay() === "drawer") {
            closeOverlay();
            return;
          }
          sidebar.classList.add("nb-open");
          navToggle.setAttribute("aria-expanded", "true");
          openOverlay("drawer", sidebar, closeDrawer, sidebar);
        });
        // Following a link inside the drawer navigates away → close it first.
        sidebar.addEventListener("click", (e) => {
          if ((e.target as HTMLElement).closest("a") && currentOverlay() === "drawer") closeOverlay();
        });
      }

      // Topbar dropdowns (Export + language): a native <details> doesn't close on an outside
      // click — wire that up (+ Escape, + close after picking an item). Opening one closes
      // the other through the same outside-click pass.
      const topMenus = Array.from(document.querySelectorAll<HTMLDetailsElement>(".export-menu, .lang-menu"));
      if (topMenus.length) {
        document.addEventListener("click", (e) => {
          for (const menu of topMenus) {
            if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
          }
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") for (const menu of topMenus) menu.open = false;
        });
        for (const menu of topMenus) {
          for (const a of menu.querySelectorAll("a")) {
            a.addEventListener("click", () => {
              menu.open = false;
            });
          }
        }
      }

      // Review badge: reveal every "Review" link (topbar + drawer) + a count of
      // `addressed` comments when in approve mode, OR whenever any addressed comment
      // exists (so none get stuck if the mode is flipped back to auto). One tiny fetch.
      const reviewCfg = JSON.parse(document.getElementById("notabene-review")?.textContent || "{}");
      const reviewLinks = Array.from(document.querySelectorAll<HTMLElement>(".js-review-link"));
      const reviewBadges = Array.from(document.querySelectorAll<HTMLElement>(".js-review-badge"));
      if (reviewLinks.length) {
        fetch("/api/comments?all=1")
          .then((r) => r.json())
          .then((all: { status: string }[]) => {
            const n = Array.isArray(all) ? all.filter((c) => c.status === "addressed").length : 0;
            if (reviewCfg.mode === "approve" || n > 0) {
              for (const l of reviewLinks) l.hidden = false;
              for (const b of reviewBadges) {
                b.textContent = n ? String(n) : "";
                b.hidden = !n;
              }
            }
          })
          .catch(() => {});
      }
    </script>

    <script>
      import { renderMermaid } from "../lib/client/mermaid";

      // Render any ```mermaid diagrams on the page (lazy-loads mermaid only if present).
      // No ClientRouter here, so a direct call covers every full page load; the listener
      // is a harmless no-op unless view transitions are added later.
      renderMermaid();
      document.addEventListener("astro:page-load", () => renderMermaid());
    </script>

    <script>
      import { esc } from "../lib/client/comments-client";
      import { localizeField } from "../lib/i18n-content.mjs";

      // Client-side search: JSON index (title + headings + excerpt), scored.
      const input = document.getElementById("search-input") as HTMLInputElement | null;
      const box = document.getElementById("search-results");

      interface Doc {
        space: string;
        locale: string;
        href: string;
        title: string;
        headings: string[];
        text: string;
      }

      const ROOTS: { key: string; label: string; path: string; labelI18n?: string | Record<string, string> }[] = JSON.parse(
        document.getElementById("notabene-roots")?.textContent || "[]",
      );
      // Scope search to the current page's language when i18n is on.
      const SEARCH_I18N = JSON.parse(document.getElementById("notabene-i18n-config")?.textContent || "null");
      const searchLocale = document.documentElement.lang || SEARCH_I18N?.defaultLocale || "";
      const M: Record<string, string> = JSON.parse(
        document.getElementById("notabene-i18n")?.textContent || "{}",
      );
      // Result chip = the space label in the search locale (per-locale `roots[].label`).
      const spaceLabel = (key: string): string => {
        const r = ROOTS.find((x) => x.key === key);
        return (r && (localizeField(r.labelI18n, searchLocale, SEARCH_I18N?.defaultLocale || searchLocale) ?? r.label)) ?? key;
      };

      let index: Doc[] | null = null;
      async function ensureIndex(): Promise<Doc[]> {
        if (!index) index = await fetch("/search-index.json").then((r) => r.json());
        return index ?? [];
      }

      function score(doc: Doc, q: string): number {
        const t = doc.title.toLowerCase();
        if (t === q) return 100;
        if (t.startsWith(q)) return 80;
        if (t.includes(q)) return 60;
        if (doc.headings.some((h) => h.toLowerCase().includes(q))) return 30;
        if (doc.text.toLowerCase().includes(q)) return 10;
        return 0;
      }

      if (input && box) {
        input.addEventListener("input", async () => {
          const q = input.value.trim().toLowerCase();
          if (!q) {
            box.hidden = true;
            box.innerHTML = "";
            return;
          }
          const data = (await ensureIndex()).filter((d) => !SEARCH_I18N?.enabled || d.locale === searchLocale);
          const hits = data
            .map((doc) => ({ doc, s: score(doc, q) }))
            .filter((x) => x.s > 0)
            .sort((a, b) => b.s - a.s)
            .slice(0, 12);
          box.innerHTML = hits.length
            ? hits
                .map(
                  ({ doc }) =>
                    `<a href="${doc.href}"><span class="r-space ${doc.space}">${esc(spaceLabel(doc.space))}</span><span class="r-title">${esc(doc.title)}</span></a>`,
                )
                .join("")
            : `<div class="r-empty">${M.searchNoResults}</div>`;
          box.hidden = false;
        });

        document.addEventListener("click", (e) => {
          const target = e.target as Node;
          if (!box.contains(target) && target !== input) box.hidden = true;
        });
      }
    </script>
  </body>
</html>
