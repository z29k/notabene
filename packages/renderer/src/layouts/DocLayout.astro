---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import Comments from "../components/Comments.astro";
import type { Space } from "../lib/nav";
import { author, authorEmail, clientI18n, clientRoots, pdf, reviewMode, siteName, tagline } from "../config.mjs";
import { t } from "../i18n.mjs";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Crumb {
  label: string;
  href?: string;
}

/** Contextual PDF export targets for the current page (built by the page route from
 *  its space + entry id). The whole-doc target (/print) is always offered. */
interface ExportScopes {
  space?: { href: string; label: string };
  folder?: { href: string; label: string };
  page?: { href: string; label: string };
}

interface Alt {
  locale: string;
  href: string;
  /** True when this is a REAL translation of the page (vs. a home fallback) — hreflang only. */
  translated?: boolean;
}

interface Props {
  title: string;
  current?: string;
  space?: Space;
  /** Chemin logique repo-relatif (sans extension) — support Phase 2 commentaires. */
  page?: string;
  /** Content locale of THIS page (per-page chrome). Aggregate pages omit it → default. */
  locale?: string;
  headings?: Heading[];
  breadcrumb?: Crumb[];
  exportScopes?: ExportScopes;
  /** Equivalent pages in other locales — drives the language switcher + hreflang. */
  alternates?: Alt[];
}

const {
  title,
  current = "",
  space,
  page,
  locale = clientI18n.defaultLocale,
  headings = [],
  breadcrumb = [],
  exportScopes,
  alternates = [],
} = Astro.props;
// UI chrome follows THIS page's locale (t() falls back to English per key).
const m = t(locale);
const showLang = clientI18n.enabled && alternates.length > 1;
// hreflang lists only REAL translations (+ x-default = the default locale's page).
const hreflangs = alternates.filter((a) => a.translated);
const xDefault = hreflangs.find((a) => a.locale === clientI18n.defaultLocale)?.href ?? hreflangs[0]?.href;
const showExport = pdf.enabled;
// Export links open the print view in a NEW TAB and auto-open the browser's print
// dialog (?autoprint=1, handled by lib/client/print.ts) — as close to "save straight to
// PDF" as a browser allows. The silent file-export path is the `notabene pdf` CLI.
const printHref = (href: string) => `${href}?autoprint=1`;
// Whole-doc PDF is per-locale (default unprefixed): /print or /print/<locale>.
const wholeDocHref = locale === clientI18n.defaultLocale ? "/print" : `/print/${locale}`;
// Doc pages (page set) carry the TOC + anchored-comment rail. App pages (review / comments /
// journal) pass no page → no rail; drop the empty third column so they use the full width.
const hasRail = page != null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} · {siteName}</title>
    <script type="application/json" id="notabene-roots" is:inline set:html={JSON.stringify(clientRoots)} />
    <script type="application/json" id="notabene-i18n" is:inline set:html={JSON.stringify(m)} />
    <script type="application/json" id="notabene-review" is:inline set:html={JSON.stringify({ mode: reviewMode })} />
    <script type="application/json" id="notabene-me" is:inline set:html={JSON.stringify({ author, email: authorEmail })} />
    <script type="application/json" id="notabene-i18n-config" is:inline set:html={JSON.stringify(clientI18n)} />
    {showLang && hreflangs.map((a) => <link rel="alternate" hreflang={a.locale} href={a.href} />)}
    {showLang && xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}
  </head>
  <body>
    <header class="topbar">
      <button
        id="nb-nav-toggle"
        class="nb-nav-toggle"
        type="button"
        aria-label={m.menu}
        aria-controls="nb-sidebar"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <a href="/" class="brand">{siteName} <span>· {tagline}</span></a>
      <div class="search">
        <input id="search-input" type="search" placeholder={m.searchPlaceholder} autocomplete="off" />
        <div id="search-results" class="search-results" hidden></div>
      </div>
      <a href="/comments" class="topbar-link topbar-util">{m.navComments}</a>
      <a href="/review" id="nav-review" class="topbar-link topbar-util js-review-link" hidden>
        {m.navReview} <span id="nav-review-badge" class="review-badge js-review-badge"></span>
      </a>
      <a href="/journal" class="topbar-link topbar-util">{m.navJournal}</a>
      {
        showLang && (
          <nav class="lang-switch topbar-util" aria-label={m.language}>
            {alternates.map((a) => (
              <a
                href={a.href}
                hreflang={a.locale}
                lang={a.locale}
                class:list={["lang-opt", { active: a.locale === locale }]}
                aria-current={a.locale === locale ? "true" : undefined}
              >
                {a.locale.toUpperCase()}
              </a>
            ))}
          </nav>
        )
      }
      {/* Flexible gap: keeps Comments/Journal on the left, pushes the ancillary
          Export + name group to the far right (desktop only — utils collapse into the
          drawer on compact). */}
      <div class="topbar-spacer topbar-util" aria-hidden="true"></div>
      {
        showExport && (
          <details class="export-menu topbar-util">
            <summary class="topbar-link export-summary" aria-label={m.exportPdf} title={m.exportPdf}>
              <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 6 2 18 2 18 9" />
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                <rect x="6" y="14" width="12" height="8" />
              </svg>
            </summary>
            <div class="export-menu-pop">
              {exportScopes?.page && (
                <a href={printHref(exportScopes.page.href)} target="_blank" rel="noopener">
                  {m.exportThisPage}
                </a>
              )}
              {exportScopes?.folder && (
                <a href={printHref(exportScopes.folder.href)} target="_blank" rel="noopener">
                  {m.exportThisFolder}
                </a>
              )}
              {exportScopes?.space && (
                <a href={printHref(exportScopes.space.href)} target="_blank" rel="noopener">
                  {m.exportThisSpace}
                </a>
              )}
              <a href={printHref(wholeDocHref)} target="_blank" rel="noopener">
                {m.exportWholeDoc}
              </a>
            </div>
          </details>
        )
      }
      <button id="nb-identity-chip" class="topbar-me topbar-util" type="button" title={m.identityHint} aria-label={m.identityHint}>
        <span aria-hidden="true">👤</span>
        <span class="nb-identity-name"></span>
      </button>
      <button id="nb-cmt-sheet-btn" class="nb-cmt-sheet-btn" type="button" hidden aria-label={m.annotations}>
        <span aria-hidden="true">💬</span> <span id="nb-cmt-sheet-count" class="nb-cmt-sheet-count"></span>
      </button>
    </header>

    <div class:list={["shell", { "shell--full": !hasRail }]}>
      <aside class="sidebar" id="nb-sidebar" tabindex="-1">
        <Sidebar current={current} activeSpace={space} locale={locale} />
        <nav class="drawer-util" aria-label={m.menu}>
          <a href="/comments" class="drawer-link">{m.navComments}</a>
          <a href="/review" class="drawer-link js-review-link" hidden>
            {m.navReview} <span class="review-badge js-review-badge"></span>
          </a>
          <a href="/journal" class="drawer-link">{m.navJournal}</a>
          {
            showLang && (
              <nav class="lang-switch-drawer" aria-label={m.language}>
                {alternates.map((a) => (
                  <a
                    href={a.href}
                    hreflang={a.locale}
                    lang={a.locale}
                    class:list={["drawer-link lang-opt", { active: a.locale === locale }]}
                    aria-current={a.locale === locale ? "true" : undefined}
                  >
                    🌐 {a.locale.toUpperCase()}
                  </a>
                ))}
              </nav>
            )
          }
          {
            showExport && (
              <>
                {exportScopes?.page && (
                  <a href={printHref(exportScopes.page.href)} target="_blank" rel="noopener" class="drawer-link">
                    🖨 {m.exportThisPage}
                  </a>
                )}
                {exportScopes?.folder && (
                  <a href={printHref(exportScopes.folder.href)} target="_blank" rel="noopener" class="drawer-link">
                    🖨 {m.exportThisFolder}
                  </a>
                )}
                {exportScopes?.space && (
                  <a href={printHref(exportScopes.space.href)} target="_blank" rel="noopener" class="drawer-link">
                    🖨 {m.exportThisSpace}
                  </a>
                )}
                <a href={printHref(wholeDocHref)} target="_blank" rel="noopener" class="drawer-link">
                  🖨 {m.exportWholeDoc}
                </a>
              </>
            )
          }
          <button id="nb-identity-chip-drawer" class="drawer-me" type="button" aria-label={m.identityHint}>
            <span aria-hidden="true">👤</span>
            <span class="nb-identity-name"></span>
          </button>
        </nav>
      </aside>

      <main class="content">
        {
          breadcrumb.length > 0 && (
            <nav class="breadcrumb" aria-label="Breadcrumb">
              {breadcrumb.map((b, i) => (
                <>
                  {i > 0 && <span class="sep">/</span>}
                  {b.href ? <a href={b.href}>{b.label}</a> : <span>{b.label}</span>}
                </>
              ))}
            </nav>
          )
        }
        {
          headings.length > 0 && (
            <details class="toc-inline">
              <summary>{m.tocTitle}</summary>
              <Toc headings={headings} locale={locale} />
            </details>
          )
        }
        <article id="doc-content" class="prose" data-space={space} data-page={page}>
          <slot />
        </article>
        <Comments page={page} space={space} locale={locale} />
      </main>

      {
        hasRail && (
          <aside class="rail">
            <Toc headings={headings} locale={locale} />
            <div id="cmt-rail" class="cmt-rail" role="region" aria-label={m.annotations} />
          </aside>
        )
      }
    </div>

    <div id="nb-scrim" class="nb-scrim" hidden></div>

    <dialog id="nb-identity-dialog" class="nb-dialog">
      <form id="nb-identity-form" class="nb-identity-form" method="dialog" novalidate>
        <h2>{m.identityTitle}</h2>
        <p id="nb-identity-lede" class="nb-identity-lede">{m.identityLede}</p>
        <label class="nb-field">
          <span class="nb-field-label">{m.identityName}</span>
          <input id="nb-identity-name" type="text" required autocomplete="name" placeholder={m.yourName} />
        </label>
        <label class="nb-field">
          <span class="nb-field-label">{m.identityEmail} <em>{m.identityEmailOptional}</em></span>
          <input id="nb-identity-email" type="email" autocomplete="email" placeholder="you@example.com" />
          <small class="nb-hint">{m.identityEmailHint}</small>
        </label>
        <div class="nb-identity-actions">
          <button type="button" id="nb-identity-cancel" class="nb-btn-ghost">{m.cancel}</button>
          <button type="submit" id="nb-identity-save" class="nb-btn">{m.save}</button>
        </div>
      </form>
    </dialog>

    <script>
      import { getIdentity, hasIdentity, isLoopbackHost, setIdentity } from "../lib/client/comments-client";
      import { closeOverlay, currentOverlay, initShell, openOverlay } from "../lib/client/shell";

      // Wire the shared scrim / Escape / resize-to-desktop overlay closers once.
      initShell();

      // Identity (name + optional email) — per-device, edited via a modal. The chips in
      // the topbar + drawer open it; on a non-loopback (LAN/`--host`/deployed) host with no
      // identity set yet, it's forced open before the visitor can interact, so comments are
      // attributed to a real person rather than the repo owner's git default.
      const meCfg = JSON.parse(document.getElementById("notabene-me")?.textContent || "{}");
      const M = JSON.parse(document.getElementById("notabene-i18n")?.textContent || "{}");
      const defName = meCfg.author || "you";
      const defEmail = meCfg.email || "";

      const dialog = document.getElementById("nb-identity-dialog") as HTMLDialogElement | null;
      const form = document.getElementById("nb-identity-form") as HTMLFormElement | null;
      const nameInput = document.getElementById("nb-identity-name") as HTMLInputElement | null;
      const emailInput = document.getElementById("nb-identity-email") as HTMLInputElement | null;
      const cancelBtn = document.getElementById("nb-identity-cancel") as HTMLButtonElement | null;
      const lede = document.getElementById("nb-identity-lede");
      const chips = Array.from(document.querySelectorAll("#nb-identity-chip, #nb-identity-chip-drawer"));
      const nameLabels = Array.from(document.querySelectorAll<HTMLElement>(".nb-identity-name"));

      let forced = false;

      const refreshChips = () => {
        const { name } = getIdentity(defName, defEmail);
        for (const el of nameLabels) el.textContent = name;
      };
      refreshChips();

      const openIdentity = (force = false) => {
        if (!dialog) return;
        forced = force;
        const known = hasIdentity();
        const cur = getIdentity(defName, defEmail);
        // On a forced remote prompt with nothing stored, start blank so the visitor
        // enters THEIR identity rather than accepting the repo owner's git default.
        if (nameInput) nameInput.value = force && !known ? "" : cur.name;
        if (emailInput) emailInput.value = force && !known ? "" : cur.email;
        if (lede) lede.textContent = force ? M.identityNudge : M.identityLede;
        if (cancelBtn) cancelBtn.hidden = force;
        if (!dialog.open) dialog.showModal();
        nameInput?.focus();
      };

      form?.addEventListener("submit", (e) => {
        e.preventDefault();
        const name = nameInput?.value.trim() || "";
        const email = emailInput?.value.trim() || "";
        if (!name) {
          nameInput?.setCustomValidity(M.identityNameRequired || "Required");
          nameInput?.reportValidity();
          return;
        }
        if (email && emailInput && !emailInput.checkValidity()) {
          emailInput.reportValidity();
          return;
        }
        setIdentity({ name, email });
        refreshChips();
        forced = false;
        dialog?.close();
      });

      nameInput?.addEventListener("input", () => nameInput.setCustomValidity(""));
      cancelBtn?.addEventListener("click", () => {
        if (!forced) dialog?.close();
      });
      // Block Escape / backdrop dismissal while the identity is being forced.
      dialog?.addEventListener("cancel", (e) => {
        if (forced) e.preventDefault();
      });
      for (const chip of chips) chip.addEventListener("click", () => openIdentity(false));

      // Gate: remote host + no identity yet → force the dialog before browsing.
      if (!isLoopbackHost(location.hostname) && !hasIdentity()) openIdentity(true);

      // Hamburger → off-canvas nav drawer (compact only; the button is CSS-hidden on
      // desktop). Uses the shared overlay machinery (scrim, inert, scroll-lock, Escape).
      const navToggle = document.getElementById("nb-nav-toggle");
      const sidebar = document.getElementById("nb-sidebar");
      if (navToggle && sidebar) {
        const closeDrawer = () => {
          sidebar.classList.remove("nb-open");
          navToggle.setAttribute("aria-expanded", "false");
        };
        navToggle.addEventListener("click", () => {
          if (currentOverlay() === "drawer") {
            closeOverlay();
            return;
          }
          sidebar.classList.add("nb-open");
          navToggle.setAttribute("aria-expanded", "true");
          openOverlay("drawer", sidebar, closeDrawer, sidebar);
        });
        // Following a link inside the drawer navigates away → close it first.
        sidebar.addEventListener("click", (e) => {
          if ((e.target as HTMLElement).closest("a") && currentOverlay() === "drawer") closeOverlay();
        });
      }

      // Export menu: a native <details> doesn't close on an outside click — wire that up
      // (+ Escape, + closing after a scope is picked, which opens the print view in a new tab).
      const exportMenu = document.querySelector<HTMLDetailsElement>(".export-menu");
      if (exportMenu) {
        document.addEventListener("click", (e) => {
          if (exportMenu.open && !exportMenu.contains(e.target as Node)) exportMenu.open = false;
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") exportMenu.open = false;
        });
        for (const a of exportMenu.querySelectorAll("a")) {
          a.addEventListener("click", () => {
            exportMenu.open = false;
          });
        }
      }

      // Review badge: reveal every "Review" link (topbar + drawer) + a count of
      // `addressed` comments when in approve mode, OR whenever any addressed comment
      // exists (so none get stuck if the mode is flipped back to auto). One tiny fetch.
      const reviewCfg = JSON.parse(document.getElementById("notabene-review")?.textContent || "{}");
      const reviewLinks = Array.from(document.querySelectorAll<HTMLElement>(".js-review-link"));
      const reviewBadges = Array.from(document.querySelectorAll<HTMLElement>(".js-review-badge"));
      if (reviewLinks.length) {
        fetch("/api/comments?all=1")
          .then((r) => r.json())
          .then((all: { status: string }[]) => {
            const n = Array.isArray(all) ? all.filter((c) => c.status === "addressed").length : 0;
            if (reviewCfg.mode === "approve" || n > 0) {
              for (const l of reviewLinks) l.hidden = false;
              for (const b of reviewBadges) {
                b.textContent = n ? String(n) : "";
                b.hidden = !n;
              }
            }
          })
          .catch(() => {});
      }
    </script>

    <script>
      import { renderMermaid } from "../lib/client/mermaid";

      // Render any ```mermaid diagrams on the page (lazy-loads mermaid only if present).
      // No ClientRouter here, so a direct call covers every full page load; the listener
      // is a harmless no-op unless view transitions are added later.
      renderMermaid();
      document.addEventListener("astro:page-load", () => renderMermaid());
    </script>

    <script>
      import { esc } from "../lib/client/comments-client";

      // Client-side search: JSON index (title + headings + excerpt), scored.
      const input = document.getElementById("search-input") as HTMLInputElement | null;
      const box = document.getElementById("search-results");

      interface Doc {
        space: string;
        locale: string;
        href: string;
        title: string;
        headings: string[];
        text: string;
      }

      const ROOTS: { key: string; label: string; path: string }[] = JSON.parse(
        document.getElementById("notabene-roots")?.textContent || "[]",
      );
      // Scope search to the current page's language when i18n is on.
      const SEARCH_I18N = JSON.parse(document.getElementById("notabene-i18n-config")?.textContent || "null");
      const searchLocale = document.documentElement.lang || SEARCH_I18N?.defaultLocale || "";
      const M: Record<string, string> = JSON.parse(
        document.getElementById("notabene-i18n")?.textContent || "{}",
      );
      const spaceLabel = (key: string): string =>
        ROOTS.find((r) => r.key === key)?.label ?? key;

      let index: Doc[] | null = null;
      async function ensureIndex(): Promise<Doc[]> {
        if (!index) index = await fetch("/search-index.json").then((r) => r.json());
        return index ?? [];
      }

      function score(doc: Doc, q: string): number {
        const t = doc.title.toLowerCase();
        if (t === q) return 100;
        if (t.startsWith(q)) return 80;
        if (t.includes(q)) return 60;
        if (doc.headings.some((h) => h.toLowerCase().includes(q))) return 30;
        if (doc.text.toLowerCase().includes(q)) return 10;
        return 0;
      }

      if (input && box) {
        input.addEventListener("input", async () => {
          const q = input.value.trim().toLowerCase();
          if (!q) {
            box.hidden = true;
            box.innerHTML = "";
            return;
          }
          const data = (await ensureIndex()).filter((d) => !SEARCH_I18N?.enabled || d.locale === searchLocale);
          const hits = data
            .map((doc) => ({ doc, s: score(doc, q) }))
            .filter((x) => x.s > 0)
            .sort((a, b) => b.s - a.s)
            .slice(0, 12);
          box.innerHTML = hits.length
            ? hits
                .map(
                  ({ doc }) =>
                    `<a href="${doc.href}"><span class="r-space ${doc.space}">${esc(spaceLabel(doc.space))}</span><span class="r-title">${esc(doc.title)}</span></a>`,
                )
                .join("")
            : `<div class="r-empty">${M.searchNoResults}</div>`;
          box.hidden = false;
        });

        document.addEventListener("click", (e) => {
          const target = e.target as Node;
          if (!box.contains(target) && target !== input) box.hidden = true;
        });
      }
    </script>
  </body>
</html>
