---
import DocLayout from "../layouts/DocLayout.astro";
import { locale, roots, siteName } from "../config.mjs";
import { t } from "../i18n.mjs";

const m = t(locale);
---

<DocLayout title="Home" i18nClientChrome>
  <h1>{siteName} <span data-i18n="homeDocumentation">{m.homeDocumentation}</span></h1>
  <p class="lede" data-i18n="homeLede">{m.homeLede}</p>

  <div class="home-cards">
    {
      roots.map((root) => (
        <a class="home-card" href={`/${root.key}`}>
          <h2>{root.label}</h2>
          <p><code>{root.subLabel}</code></p>
          {root.description && <p>{root.description}</p>}
        </a>
      ))
    }
  </div>
</DocLayout>
