---
// Site home for the DEFAULT locale (`/`). Non-default-locale homes (`/en`, …) are emitted by
// the site-home branch of `[...path].astro`. Both render the shared, per-locale SiteHome.
import SiteHome from "../components/SiteHome.astro";
import { i18n } from "../config.mjs";
---

<SiteHome locale={i18n.defaultLocale} />
