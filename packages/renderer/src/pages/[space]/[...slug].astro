---
import { getCollection, render } from "astro:content";
import DocLayout from "../../layouts/DocLayout.astro";
import SpaceIndex from "../../components/SpaceIndex.astro";
import { buildNav, humanize, pageTitle, type NavNode } from "../../lib/nav";
import { scopeToPath } from "../../lib/print-scope";
import { pdf, roots } from "../../config.mjs";

export async function getStaticPaths() {
  const groups = await Promise.all(
    roots.map(async (root) => {
      const entries = await getCollection(root.key as never);
      // Dynamic collection (name = space key) → entries aren't statically typed;
      // `entry` flows into props and is consumed via render()/entry.body downstream.
      // biome-ignore lint/suspicious/noExplicitAny: dynamic Astro collection entry.
      const docs = entries.map((entry: any) => ({
        params: { space: root.key, slug: entry.id },
        props: { spaceKey: root.key, entry },
      }));
      // Space home page (empty slug → /<key>).
      return [...docs, { params: { space: root.key, slug: undefined }, props: { spaceKey: root.key, entry: undefined } }];
    }),
  );
  return groups.flat();
}

const { spaceKey, entry } = Astro.props;
const root = roots.find((r) => r.key === spaceKey)!;
const spaceLabel = root.label;
const baseDir = root.path;

let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let headings: { depth: number; slug: string; text: string }[] = [];
let nodes: NavNode[] = [];
let page: string | undefined;
let title = spaceLabel;
const breadcrumb: { label: string; href?: string }[] = [{ label: spaceLabel, href: `/${spaceKey}` }];

if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
  headings = rendered.headings;
  title = pageTitle(entry.body, entry.id);
  page = `${baseDir}/${entry.id}`;
  const parts = entry.id.split("/");
  for (let i = 0; i < parts.length - 1; i++) breadcrumb.push({ label: humanize(parts[i]) });
  breadcrumb.push({ label: title });
} else {
  // Space home: render the root README/index if present, else index cards.
  const all = await getCollection(spaceKey as never);
  const readme = all.find((e: { id: string }) => /^(readme|index)$/i.test(e.id));
  if (readme) {
    const rendered = await render(readme);
    // Dynamic collection → `readme` is untyped; read the fields we need via an alias.
    const meta = readme as unknown as { id: string; body?: string };
    Content = rendered.Content;
    headings = rendered.headings;
    title = pageTitle(meta.body, meta.id);
    page = `${baseDir}/${meta.id}`;
  } else {
    nodes = await buildNav(spaceKey);
  }
}

const current = entry ? `/${spaceKey}/${entry.id}` : `/${spaceKey}`;

// Contextual PDF export targets: always the space; plus the page's folder + the page
// itself when viewing a real entry. The whole-doc target is added by DocLayout.
let exportScopes:
  | { space?: { href: string; label: string }; folder?: { href: string; label: string }; page?: { href: string; label: string } }
  | undefined;
if (pdf.enabled) {
  exportScopes = { space: { href: scopeToPath({ kind: "space", space: spaceKey }), label: spaceLabel } };
  if (entry) {
    const idParts = entry.id.split("/");
    if (idParts.length > 1) {
      const folderPath = idParts.slice(0, -1).join("/");
      exportScopes.folder = {
        href: scopeToPath({ kind: "folder", space: spaceKey, path: folderPath }),
        label: humanize(idParts[idParts.length - 2]),
      };
    }
    exportScopes.page = { href: scopeToPath({ kind: "page", space: spaceKey, id: entry.id }), label: title };
  }
}
---

<DocLayout
  title={title}
  current={current}
  space={spaceKey}
  page={page}
  headings={headings}
  breadcrumb={entry ? breadcrumb : []}
  exportScopes={exportScopes}
>
  {Content ? <Content /> : <SpaceIndex nodes={nodes} space={spaceKey} />}
</DocLayout>
