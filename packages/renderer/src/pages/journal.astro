---
export const prerender = false;
import DocLayout from "../layouts/DocLayout.astro";
import { readJournal } from "../lib/journal";
import { locale, routeForPage as routeFor } from "../config.mjs";
import { t } from "../i18n.mjs";

const m = t(locale);
const entries = (await readJournal()).slice().reverse(); // most recent first
---

<DocLayout title={m.journalTitle} i18nClientChrome>
  <h1 data-i18n="journalHeading">{m.journalHeading}</h1>
  <p class="lede" data-i18n="journalLede">{m.journalLede}</p>

  {
    entries.length === 0 ? (
      <p class="cmt-empty" data-i18n="journalEmpty">{m.journalEmpty}</p>
    ) : (
      <div class="journal">
        {entries.map((e) => (
          <section class="journal-entry">
            <header class="journal-head">
              <span class="journal-date" data-i18n-date={e.date}>
                {new Date(`${e.date}T00:00:00Z`).toLocaleDateString(locale, { dateStyle: "medium", timeZone: "UTC" })}
              </span>
              <h2>{e.title}</h2>
            </header>
            <p class="journal-summary">{e.summary}</p>
            <ul class="journal-changes">
              {e.changes.map((c) => (
                <li>
                  <a href={routeFor(c.page)} class="journal-page">
                    {c.page}
                  </a>
                  <span class="journal-what"> — {c.what}</span>
                  <div class="journal-why">{c.why}</div>
                  {c.commentIds.length > 0 && (
                    <div class="journal-cids"><span data-i18n="journalComments">{m.journalComments}</span> {c.commentIds.join(", ")}</div>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )
  }
</DocLayout>
