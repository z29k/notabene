---
// Google-Docs-style comments.
//  - Anchored (selection) → right rail (#cmt-rail, provided by DocLayout) + highlight.
//  - Page-wide            → discussion section at the BOTTOM of the page (rendered here).
// Floating button + popover in position:fixed (viewport coords). Persisted via /api/comments.
import { locale } from "../config.mjs";
import { t } from "../i18n.mjs";

interface Props {
  page?: string;
  space?: string;
}
const m = t(locale);
const { page, space } = Astro.props;
---

{
  page && (
    <section id="cmt-page" class="cmt-page" data-page={page} data-space={space}>
      <header class="cmt-page-head">
        <h2>{m.discussion}</h2>
        <span id="cmt-count" class="cmt-count" />
      </header>
      <form id="cmt-composer" class="cmt-composer">
        <textarea id="cmt-input" rows="3" placeholder={m.pageCommentPlaceholder} />
        <button type="submit">{m.commentPage}</button>
      </form>
      <div id="cmt-page-list" class="cmt-list" />
    </section>

    <button id="cmt-float" class="cmt-float" hidden type="button" aria-haspopup="dialog" aria-label={m.floatComment}>
      {m.floatComment}
    </button>
    <div id="cmt-pop" class="cmt-pop" hidden role="dialog" aria-label={m.selectionPlaceholder}>
      <div id="cmt-pop-quote" class="cmt-pop-quote" />
      <textarea id="cmt-pop-input" rows="3" placeholder={m.selectionPlaceholder} aria-label={m.selectionPlaceholder} />
      <div class="cmt-pop-actions">
        <button type="button" id="cmt-pop-cancel">{m.cancel}</button>
        <button type="button" id="cmt-pop-save">{m.comment}</button>
      </div>
    </div>

    <div id="cmt-view" class="cmt-view" hidden>
      <div class="cmt-view-list" />
    </div>
  )
}

<script>
  import { ICONS } from "../lib/icons";
  import { createApi, esc, fmt, getAuthor, type Comment, type CommentAnchor } from "../lib/client/comments-client";
  import { closeOverlay, currentOverlay, isCompact, openOverlay } from "../lib/client/shell";
  type Anchor = CommentAnchor;

  const pageSection = document.getElementById("cmt-page");
  const article = document.getElementById("doc-content");
  if (pageSection && article) {
    const NB_ROOTS: { key: string }[] = JSON.parse(
      document.getElementById("notabene-roots")?.textContent || "[]",
    );
    const M: Record<string, string> = JSON.parse(
      document.getElementById("notabene-i18n")?.textContent || "{}",
    );
    const page = pageSection.dataset.page!;
    // data-space is always set by the [space] route; fallback = first space.
    const space = pageSection.dataset.space || NB_ROOTS[0]?.key || "";
    const railEl = document.getElementById("cmt-rail");
    const pageListEl = document.getElementById("cmt-page-list")!;
    const countEl = document.getElementById("cmt-count")!;
    const inputEl = document.getElementById("cmt-input") as HTMLTextAreaElement;
    const floatBtn = document.getElementById("cmt-float")!;
    const pop = document.getElementById("cmt-pop")!;
    const popQuote = document.getElementById("cmt-pop-quote")!;
    const popInput = document.getElementById("cmt-pop-input") as HTMLTextAreaElement;
    const viewEl = document.getElementById("cmt-view")!;
    const railAside = document.querySelector(".rail") as HTMLElement | null;
    const sheetBtn = document.getElementById("nb-cmt-sheet-btn");
    const sheetCount = document.getElementById("nb-cmt-sheet-count");

    // The three fixed overlays live at <body> level so an open sheet can make the whole
    // shell (topbar/sidebar/content/rail) `inert` without disabling itself. Position is
    // fixed, so relocating them in the DOM has no visual effect on desktop.
    document.body.append(floatBtn, pop, viewEl);
    // On a doc page the 💬 sheet-open button is relevant (CSS hides it on desktop).
    if (sheetBtn) sheetBtn.hidden = false;

    let comments: Comment[] = [];
    let railFilter = "open";
    let pendingAnchor: Anchor | null = null;
    let viewIds: string[] = [];
    const ranges = new Map<string, Range>();

    const api = createApi(page);
    // Comment author: per-device localStorage name, else the injected server default.
    const AUTHOR_DEFAULT = JSON.parse(document.getElementById("notabene-me")?.textContent || "{}").author || "you";
    const me = () => getAuthor(AUTHOR_DEFAULT);

    // ── flat text mapping (offset ⇄ DOM) ──────────────────────────────────
    // Built ONCE and reused. The article's text is immutable after render — comment
    // highlights use the CSS Custom Highlight API (no DOM mutation), and the fallback
    // doesn't wrap either — so re-walking all text nodes per comment per render (the
    // old cost: ~2·N walks per pass) is pure waste.
    let flat: { text: string; map: { node: Node; start: number; end: number }[] } | null = null;
    function buildFlat() {
      if (flat) return flat;
      const walker = document.createTreeWalker(article!, NodeFilter.SHOW_TEXT);
      let text = "";
      const map: { node: Node; start: number; end: number }[] = [];
      let n: Node | null;
      while ((n = walker.nextNode())) {
        const start = text.length;
        text += n.nodeValue || "";
        map.push({ node: n, start, end: text.length });
      }
      flat = { text, map };
      return flat;
    }
    function pointToOffset(map: { node: Node; start: number }[], node: Node, off: number) {
      for (const m of map) if (m.node === node) return m.start + off;
      return -1;
    }
    function offsetToPoint(map: { node: Node; start: number; end: number }[], offset: number) {
      for (const m of map) if (offset <= m.end) return { node: m.node, offset: offset - m.start };
      const last = map[map.length - 1];
      return { node: last.node, offset: last.end - last.start };
    }
    function nearestSection(node: Node): string | null {
      const heads = [...article!.querySelectorAll("h1,h2,h3,h4")];
      let best: Element | null = null;
      for (const h of heads)
        if (h.compareDocumentPosition(node) & Node.DOCUMENT_POSITION_FOLLOWING) best = h;
      return best ? best.textContent!.trim() : null;
    }
    function computeAnchor(range: Range): Anchor {
      const { text, map } = buildFlat();
      const start = pointToOffset(map, range.startContainer, range.startOffset);
      const end = pointToOffset(map, range.endContainer, range.endOffset);
      return {
        quote: text.slice(start, end),
        prefix: text.slice(Math.max(0, start - 40), start),
        suffix: text.slice(end, end + 40),
        section: nearestSection(range.startContainer),
      };
    }
    function findRange(anchor: Anchor): Range | null {
      const { text, map } = buildFlat();
      if (!anchor.quote) return null;
      let idx = text.indexOf(anchor.prefix + anchor.quote + anchor.suffix);
      idx = idx >= 0 ? idx + anchor.prefix.length : text.indexOf(anchor.quote);
      if (idx < 0) return null;
      const s = offsetToPoint(map, idx);
      const e = offsetToPoint(map, idx + anchor.quote.length);
      const r = document.createRange();
      try {
        r.setStart(s.node, s.offset);
        r.setEnd(e.node, e.offset);
      } catch {
        return null;
      }
      return r;
    }
    function applyHighlights() {
      ranges.clear();
      // Re-anchor every visible selection comment into a live Range ALWAYS: the
      // `ranges` map powers click-to-open and jump-to-comment, which must keep
      // working even where the browser can't paint highlights.
      const found: Range[] = [];
      for (const c of comments) {
        if (c.scope !== "selection" || !c.anchor || c.status === "resolved") continue;
        const r = findRange(c.anchor);
        if (r) {
          ranges.set(c.id, r);
          found.push(r);
        }
      }
      // Paint via the CSS Custom Highlight API when available; otherwise degrade
      // gracefully (interactions above still work) and warn once.
      const C = window.CSS as any;
      if (C?.highlights && typeof (window as any).Highlight === "function") {
        const hl = new (window as any).Highlight();
        for (const r of found) hl.add(r);
        C.highlights.set("cmt", hl);
      } else if (found.length) {
        warnNoHighlightSupport();
      }
    }

    // Non-blocking, dismissible banner shown once when the Highlight API is missing
    // (older Firefox/Safari). Appended to <body>, not the article, so it doesn't
    // perturb the flat text map. Styles inline to avoid touching global.css.
    let noHlWarned = false;
    function warnNoHighlightSupport() {
      if (noHlWarned) return;
      noHlWarned = true;
      const bar = document.createElement("div");
      bar.textContent = M.noHighlightSupport || "This browser can't paint comment highlights — clicking still works.";
      bar.style.cssText =
        "position:fixed;bottom:12px;left:50%;transform:translateX(-50%);z-index:9999;" +
        "background:#7a1f1f;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;" +
        "font:13px system-ui,sans-serif;box-shadow:0 2px 10px rgba(0,0,0,.35);max-width:90vw";
      bar.title = "Dismiss";
      bar.addEventListener("click", () => bar.remove());
      document.body.appendChild(bar);
    }

    // ── card rendering (shared) ────────────────────────────────────────────
    function card(c: Comment): string {
      const head = c.thread[0];
      const replies = c.thread.slice(1);
      const orphan = c.scope === "selection" && c.anchor && !findRange(c.anchor);
      return `<article class="cmt-card ${c.status}${c.hold ? " held" : ""}" data-id="${c.id}">
        <div class="cmt-meta"><span class="cmt-dot ${c.status}"></span>
          ${
            c.scope === "selection"
              ? `<span class="cmt-quote${orphan ? " orphan" : ""}" data-jump="${c.id}">${orphan ? "⚠ " : ""}“${esc((c.anchor?.quote || "").slice(0, 70))}”</span>`
              : `<span class="cmt-scope">${M.scopePage}</span>`
          }
          ${c.hold ? `<span class="cmt-hold-badge">${M.onHold}</span>` : ""}
        </div>
        <div class="cmt-body"><b>${esc(head.author)}</b> ${esc(head.body)}</div>
        ${replies.map((r) => `<div class="cmt-reply"><b>${esc(r.author)}</b> ${esc(r.body)}</div>`).join("")}
        ${c.resolution?.note ? `<div class="cmt-resolution">✔ ${esc(c.resolution.note)}</div>` : ""}
        <div class="cmt-actions">
          <span class="cmt-ts">${fmt(head.ts)}</span>
          ${c.status === "open" && c.thread.length === 1 ? `<button data-act="edit" data-id="${c.id}" title="${M.tEdit}" aria-label="${M.tEdit}">${ICONS.edit}</button>` : ""}
          ${
            c.status === "resolved"
              ? `<button data-act="reopen" data-id="${c.id}" title="${M.tReopen}" aria-label="${M.tReopen}">${ICONS.reopen}</button>`
              : c.status === "addressed"
                ? `<a class="cmt-tovalidate" href="/review" title="${M.filterToValidate}" aria-label="${M.filterToValidate}">${M.filterToValidate} →</a>`
                : `<button data-act="resolve" data-id="${c.id}" title="${M.tResolve}" aria-label="${M.tResolve}">${ICONS.check}</button>`
          }
          <button data-act="${c.hold ? "unhold" : "hold"}" data-id="${c.id}" title="${c.hold ? M.tUnhold : M.tHold}" aria-label="${c.hold ? M.tUnhold : M.tHold}">${c.hold ? ICONS.play : ICONS.pause}</button>
          <button data-act="reply" data-id="${c.id}" title="${M.tReply}" aria-label="${M.tReply}">${ICONS.reply}</button>
          <button data-act="delete" data-id="${c.id}" class="danger" title="${M.tDelete}" aria-label="${M.tDelete}">${ICONS.trash}</button>
        </div>
        <form class="cmt-reply-form" data-id="${c.id}" hidden>
          <textarea rows="2" placeholder="${M.replyPlaceholder}"></textarea><button type="submit">${M.send}</button>
        </form>
        <form class="cmt-edit-form" data-id="${c.id}" hidden>
          <textarea rows="2">${esc(head.body)}</textarea><button type="submit">${M.save}</button>
        </form>
      </article>`;
    }

    function render() {
      const anchored = comments.filter((c) => c.scope === "selection");
      const pageWide = comments.filter((c) => c.scope === "page");
      const openCount = comments.filter((c) => c.status !== "resolved").length;
      countEl.textContent = openCount ? `${openCount} ${M.openSuffix}` : `${comments.length}`;
      if (sheetCount) {
        const openAnchored = anchored.filter((c) => c.status !== "resolved").length;
        sheetCount.textContent = openAnchored ? String(openAnchored) : "";
      }

      // right rail: anchored comments
      if (railEl) {
        const shown = anchored.filter((c) =>
          railFilter === "all"
            ? true
            : railFilter === "resolved"
              ? c.status === "resolved"
              : railFilter === "addressed"
                ? c.status === "addressed"
                : c.status !== "resolved",
        );
        railEl.innerHTML = `<div class="cmt-rail-head">
            <span class="cmt-rail-title">${M.annotations}</span>
            <span class="cmt-rail-count">${anchored.length}</span>
          </div>
          <div class="cmt-filter" id="cmt-filter">
            <button data-f="open"${railFilter === "open" ? ' class="active"' : ""}>${M.filterOpen}</button>
            <button data-f="addressed"${railFilter === "addressed" ? ' class="active"' : ""}>${M.filterToValidate}</button>
            <button data-f="resolved"${railFilter === "resolved" ? ' class="active"' : ""}>${M.filterResolved}</button>
            <button data-f="all"${railFilter === "all" ? ' class="active"' : ""}>${M.filterAll}</button>
          </div>
          <div class="cmt-list">${
            shown.length ? shown.map(card).join("") : `<p class="cmt-empty">${M.selectToAnnotate}</p>`
          }</div>`;
      }
      // page bottom: page-wide comments
      pageListEl.innerHTML = pageWide.length
        ? pageWide.map(card).join("")
        : `<p class="cmt-empty">${M.noPageComments}</p>`;
      applyHighlights();
    }

    async function load() {
      comments = await api("GET");
      render();
      renderView();
    }

    // ── tap on highlighted text → reading sheet (compact) / popover (desktop) ─
    function renderView() {
      const cs = comments.filter((c) => viewIds.includes(c.id));
      if (!cs.length) {
        viewEl.hidden = true;
        return;
      }
      (viewEl.querySelector(".cmt-view-list") as HTMLElement).innerHTML = cs.map(card).join("");
      viewEl.hidden = false;
    }
    // Highlights are painted (CSS Custom Highlight API), not DOM nodes, so hit-test the
    // point against each comment range's client rects, inflated for fat fingers.
    function hitComments(x: number, y: number): string[] {
      const PADX = 4;
      const PADY = 10;
      const hit: string[] = [];
      for (const [cid, r] of ranges) {
        for (const rect of r.getClientRects()) {
          if (x >= rect.left - PADX && x <= rect.right + PADX && y >= rect.top - PADY && y <= rect.bottom + PADY) {
            hit.push(cid);
            break;
          }
        }
      }
      return hit;
    }
    function openView(x: number, y: number) {
      viewIds = hitComments(x, y);
      if (!viewIds.length) {
        if (currentOverlay() === "sheet-read") closeOverlay();
        else viewEl.hidden = true;
        return;
      }
      renderView();
      if (isCompact()) {
        viewEl.style.top = "";
        viewEl.style.left = "";
        if (currentOverlay() !== "sheet-read") {
          openOverlay("sheet-read", viewEl, () => {
            viewEl.hidden = true;
            viewIds = [];
          });
        }
      } else {
        viewEl.style.top = `${Math.max(8, Math.min(window.innerHeight - 80, y + 10))}px`;
        viewEl.style.left = `${Math.max(8, Math.min(window.innerWidth - 340, x))}px`;
      }
    }
    // Distinguish a tap (open) from a drag (select) by movement — never read the global
    // selection, so a lingering touch selection can't swallow the tap.
    let tapStart: { x: number; y: number } | null = null;
    article.addEventListener("pointerdown", (e) => {
      const pe = e as PointerEvent;
      tapStart = { x: pe.clientX, y: pe.clientY };
    });
    article.addEventListener("pointerup", (e) => {
      const pe = e as PointerEvent;
      const start = tapStart;
      tapStart = null;
      if (!start || (e.target as HTMLElement).closest("a")) return;
      if (Math.hypot(pe.clientX - start.x, pe.clientY - start.y) > 8) return;
      openView(pe.clientX, pe.clientY);
    });

    // ── selection → comment affordance → compose (mouse, keyboard AND touch) ──
    let savedRange: Range | null = null;
    let pointerDown = false;
    let lastPointerType = "mouse";
    let selTimer: ReturnType<typeof setTimeout>;

    // Coarse pointer (or a touch just happened) → dock the affordance as a bottom bar
    // rather than a small button above the selection, which collides with the iOS callout.
    const coarse = () => lastPointerType === "touch" || matchMedia("(pointer: coarse)").matches;

    // Show the comment affordance for any non-collapsed selection inside the article,
    // regardless of how it was made (mouse, keyboard, touch, or AT selection handles).
    function updateFloatFromSelection() {
      const sel = window.getSelection();
      if (!sel || sel.isCollapsed || sel.rangeCount === 0 || !sel.toString().trim()) {
        floatBtn.hidden = true;
        return;
      }
      const range = sel.getRangeAt(0);
      if (!article!.contains(range.commonAncestorContainer)) {
        floatBtn.hidden = true;
        return;
      }
      savedRange = range.cloneRange();
      if (coarse()) {
        floatBtn.classList.add("cmt-float--bar");
        floatBtn.style.top = "";
        floatBtn.style.left = "";
      } else {
        floatBtn.classList.remove("cmt-float--bar");
        const rect = range.getBoundingClientRect();
        floatBtn.style.top = `${Math.max(8, rect.top - 40)}px`;
        floatBtn.style.left = `${rect.left}px`;
      }
      floatBtn.hidden = false;
    }

    document.addEventListener("pointerdown", (e) => {
      pointerDown = true;
      lastPointerType = (e as PointerEvent).pointerType || "mouse";
    });
    // pointerup covers mouse, touch AND pen (was mouseup = mouse only).
    document.addEventListener("pointerup", (e) => {
      pointerDown = false;
      if (
        (e.target as HTMLElement).closest(
          "#cmt-float,#cmt-pop,#cmt-page,#cmt-rail,#cmt-view,#nb-scrim,#nb-cmt-sheet-btn,.rail,.sidebar",
        )
      )
        return;
      updateFloatFromSelection();
    });
    // Keyboard selection (Shift+arrows / Home / End) fires no pointer event.
    document.addEventListener("keyup", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.shiftKey || ke.key === "Home" || ke.key === "End") updateFloatFromSelection();
    });
    // Touch handles / AT adjust the selection without a pointerup — debounced fallback.
    document.addEventListener("selectionchange", () => {
      if (pointerDown) return; // a drag is in progress → handled on pointerup
      clearTimeout(selTimer);
      selTimer = setTimeout(updateFloatFromSelection, 120);
    });
    // pointerdown (not mousedown) preventDefault keeps the press from collapsing the
    // selection / stealing focus on touch; the anchor is read from savedRange regardless.
    floatBtn.addEventListener("pointerdown", (e) => e.preventDefault());
    floatBtn.addEventListener("click", openCompose);

    function openCompose() {
      if (!savedRange) return;
      pendingAnchor = computeAnchor(savedRange);
      popQuote.textContent = `“${pendingAnchor.quote.slice(0, 120)}”`;
      popInput.value = "";
      floatBtn.hidden = true;
      if (isCompact()) {
        pop.style.top = ""; // let CSS anchor it as a bottom sheet
        pop.style.left = "";
        pop.hidden = false;
        openOverlay("sheet-compose", pop, hideComposeVisual, popInput);
      } else {
        const rect = savedRange.getBoundingClientRect();
        pop.style.top = `${Math.max(8, Math.min(window.innerHeight - 180, rect.bottom + 8))}px`;
        pop.style.left = `${Math.max(8, Math.min(window.innerWidth - 320, rect.left))}px`;
        pop.hidden = false;
        popInput.focus();
      }
    }
    function hideComposeVisual() {
      pop.hidden = true;
      pendingAnchor = null;
    }
    function hideCompose() {
      if (currentOverlay() === "sheet-compose") closeOverlay();
      else hideComposeVisual();
    }
    document.getElementById("cmt-pop-cancel")!.addEventListener("click", hideCompose);
    document.getElementById("cmt-pop-save")!.addEventListener("click", async () => {
      const body = popInput.value.trim();
      if (!body || !pendingAnchor) return;
      await api("POST", { page, space, scope: "selection", anchor: pendingAnchor, author: me(), body });
      window.getSelection()?.removeAllRanges();
      hideCompose();
      await load();
    });
    // Keyboard: Ctrl/Cmd+Enter saves the selection comment without reaching for the mouse.
    popInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        (document.getElementById("cmt-pop-save") as HTMLButtonElement).click();
      }
    });
    inputEl.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        (document.getElementById("cmt-composer") as HTMLFormElement).requestSubmit();
      }
    });
    // Desktop outside-dismiss for the lightweight popovers. On compact these are sheets
    // dismissed via the scrim/Escape (shell.ts) — skip while an overlay owns the screen.
    document.addEventListener("pointerdown", (e) => {
      if (currentOverlay()) return;
      const t = e.target as HTMLElement;
      if (!t.closest("#cmt-pop,#cmt-float")) {
        pop.hidden = true;
        if (!window.getSelection()?.toString().trim()) floatBtn.hidden = true;
      }
      // Close the reading popover unless the press is inside it or back in the
      // content (the content tap handler reopens it when hitting a highlight).
      if (!t.closest("#cmt-view") && !article!.contains(t)) {
        viewIds = [];
        viewEl.hidden = true;
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !currentOverlay()) {
        pop.hidden = true;
        viewEl.hidden = true;
        viewIds = [];
      }
    });

    // ── page composer ──────────────────────────────────────────────────────
    document.getElementById("cmt-composer")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const body = inputEl.value.trim();
      if (!body) return;
      await api("POST", { page, space, scope: "page", anchor: null, author: me(), body });
      inputEl.value = "";
      await load();
    });

    // ── actions (delegation on both regions) ───────────────────────────────
    async function onActionClick(e: Event) {
      const t = e.target as HTMLElement;
      const jump = t.closest("[data-jump]") as HTMLElement | null;
      if (jump) {
        const r = ranges.get(jump.dataset.jump!);
        if (r) {
          (r.startContainer.parentElement || article)!.scrollIntoView({ behavior: "smooth", block: "center" });
          const C = window.CSS as any;
          if (C?.highlights) {
            C.highlights.set("cmt-active", new (window as any).Highlight(r));
            setTimeout(() => C.highlights.delete("cmt-active"), 1500);
          }
        }
        return;
      }
      const btn = t.closest("button[data-act]") as HTMLElement | null;
      if (!btn) return;
      const id = btn.dataset.id!;
      const act = btn.dataset.act!;
      if (act === "resolve" || act === "reopen") {
        await api("PATCH", { page, id, status: act === "resolve" ? "resolved" : "open" });
        await load();
      } else if (act === "hold" || act === "unhold") {
        await api("PATCH", { page, id, hold: act === "hold" });
        await load();
      } else if (act === "delete") {
        await api("DELETE", { page, id });
        await load();
      } else if (act === "reply") {
        const form = (btn.closest(".cmt-card") as HTMLElement).querySelector(".cmt-reply-form") as HTMLElement;
        form.hidden = !form.hidden;
        if (!form.hidden) (form.querySelector("textarea") as HTMLTextAreaElement).focus();
      } else if (act === "edit") {
        const form = (btn.closest(".cmt-card") as HTMLElement).querySelector(".cmt-edit-form") as HTMLElement;
        form.hidden = !form.hidden;
        if (!form.hidden) {
          const ta = form.querySelector("textarea") as HTMLTextAreaElement;
          ta.focus();
          ta.setSelectionRange(ta.value.length, ta.value.length);
        }
      }
    }
    async function onFormSubmit(e: Event) {
      const t = e.target as HTMLElement;
      const editForm = t.closest(".cmt-edit-form") as HTMLElement | null;
      if (editForm) {
        e.preventDefault();
        const ta = editForm.querySelector("textarea") as HTMLTextAreaElement;
        if (!ta.value.trim()) return;
        await api("PATCH", { page, id: editForm.dataset.id, edit: { body: ta.value.trim() } });
        await load();
        return;
      }
      const form = t.closest(".cmt-reply-form") as HTMLElement | null;
      if (!form) return;
      e.preventDefault();
      const ta = form.querySelector("textarea") as HTMLTextAreaElement;
      if (!ta.value.trim()) return;
      await api("PATCH", { page, id: form.dataset.id, reply: { author: me(), body: ta.value.trim() } });
      await load();
    }
    for (const region of [railEl, pageListEl, viewEl]) {
      if (!region) continue;
      region.addEventListener("click", onActionClick);
      region.addEventListener("submit", onFormSubmit);
    }
    // rail filter — delegated because re-rendered
    railEl?.addEventListener("click", (e) => {
      const b = (e.target as HTMLElement).closest("#cmt-filter button");
      if (!b) return;
      railFilter = (b as HTMLElement).dataset.f!;
      render();
    });

    // 💬 topbar button → open the anchored-comments list as a bottom sheet (compact).
    sheetBtn?.addEventListener("click", () => {
      if (!railAside) return;
      if (currentOverlay() === "sheet-list") {
        closeOverlay();
        return;
      }
      railAside.classList.add("nb-sheet");
      openOverlay("sheet-list", railAside, () => railAside.classList.remove("nb-sheet"));
    });

    // Focus a comment targeted from the global page (?c=<id>).
    function focusFromUrl() {
      const cid = new URLSearchParams(location.search).get("c");
      if (!cid) return;
      const c = comments.find((x) => x.id === cid);
      if (!c) return;
      const r = ranges.get(cid);
      if (c.scope === "selection" && r) {
        (r.startContainer.parentElement || article)!.scrollIntoView({ behavior: "smooth", block: "center" });
        const C = window.CSS as any;
        if (C?.highlights) {
          C.highlights.set("cmt-active", new (window as any).Highlight(r));
          setTimeout(() => C.highlights.delete("cmt-active"), 2500);
        }
        viewIds = [cid];
        renderView();
        if (isCompact()) {
          viewEl.style.top = "";
          viewEl.style.left = "";
          openOverlay("sheet-read", viewEl, () => {
            viewEl.hidden = true;
            viewIds = [];
          });
        } else {
          const rect = r.getBoundingClientRect();
          viewEl.style.top = `${Math.max(8, Math.min(window.innerHeight - 80, rect.bottom + 10))}px`;
          viewEl.style.left = `${Math.max(8, Math.min(window.innerWidth - 340, rect.left))}px`;
        }
      } else {
        document.getElementById("cmt-page")?.scrollIntoView({ behavior: "smooth" });
      }
    }

    load().then(focusFromUrl);
  }
</script>
