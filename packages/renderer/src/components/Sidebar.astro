---
import { buildNav, type Space } from "../lib/nav";
import NavTree from "./NavTree.astro";
import { clientI18n, i18n, roots } from "../config.mjs";
import { routeFor } from "../lib/i18n-content.mjs";
import { t } from "../i18n.mjs";

interface Props {
  current?: string;
  activeSpace?: Space;
  /** Content locale of the current page — the nav shows this locale only. */
  locale?: string;
}

const { current = "", activeSpace, locale = clientI18n.defaultLocale } = Astro.props;
const m = t(locale);
// One nav tree per space, filtered to the current locale (i18n) with clean prefixed hrefs.
const spaces = await Promise.all(
  roots.map(async (root) => ({
    root,
    nodes: await buildNav(root.key, locale),
    home: routeFor({ space: root.key, id: "", locale }, i18n),
  })),
);
---

<div class="nav-filter">
  <input id="nav-filter" type="search" placeholder={m.sidebarFilter} autocomplete="off" />
</div>

<nav class="nav">
  {
    spaces.map(({ root, nodes, home }) => (
      <details class="space" open={!activeSpace || activeSpace === root.key}>
        <summary class="space-title">
          <span class="space-name">{root.label}</span>
          <span class="space-sub">{root.subLabel}</span>
        </summary>
        <p class="space-link"><a href={home}>{m.sidebarOverview}</a></p>
        <NavTree nodes={nodes} current={current} />
      </details>
    ))
  }
</nav>

<script>
  // Client-side filter: hide leaves whose title doesn't match, and expand all
  // groups while searching.
  const input = document.getElementById("nav-filter") as HTMLInputElement | null;
  if (input) {
    input.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      for (const a of document.querySelectorAll<HTMLElement>(".nav a[data-title]")) {
        const li = a.closest("li");
        if (!li) continue;
        const hit = !q || (a.dataset.title ?? "").toLowerCase().includes(q);
        li.style.display = hit ? "" : "none";
      }
      if (q) {
        for (const d of document.querySelectorAll<HTMLDetailsElement>(".nav details")) {
          d.open = true;
        }
      }
    });
  }
</script>
