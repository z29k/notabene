---
import type { NavNode, NavLeaf, Space } from "../lib/nav";
import { clientI18n, i18n, roots } from "../config.mjs";
import { localizeField } from "../lib/i18n-content.mjs";
import { t } from "../i18n.mjs";

interface Props {
  nodes: NavNode[];
  space: Space;
  locale?: string;
}

const { nodes, space, locale = clientI18n.defaultLocale } = Astro.props;
const m = t(locale);
const root = roots.find((r) => r.key === space);
// Title + blurb follow the rendered locale (per-locale `roots[].label`/`description`).
const label = (root && localizeField(root.labelI18n, locale, i18n.defaultLocale)) ?? root?.label ?? space;
const blurb = (root && localizeField(root.descriptionI18n, locale, i18n.defaultLocale)) || `${root?.subLabel ?? space}`;
---

<h1>{label}</h1>
<p class="lede">{blurb}</p>

<div class="cards">
  {
    nodes.map((n) =>
      n.type === "group" ? (
        <section class="card">
          <h3>{n.label}</h3>
          <ul>
            {n.children
              .filter((c): c is NavLeaf => c.type === "leaf")
              .map((c) => (
                <li>
                  <a href={c.href}>{c.title}</a>
                </li>
              ))}
          </ul>
          {n.children.some((c) => c.type === "group") && <p class="more">{m.subsections}</p>}
        </section>
      ) : (
        <section class="card card-leaf">
          <h3>
            <a href={n.href}>{n.title}</a>
          </h3>
        </section>
      ),
    )
  }
</div>
